<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.*?>

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="ch.ti.gagi.xsleditor.ui.MainController"
    stylesheets="@main.css"
    minWidth="900"
    minHeight="600">

    <!-- TOP: Menu bar + Toolbar -->
    <top>
        <VBox>
            <MenuBar fx:id="menuBar">
                <Menu text="File">
                    <MenuItem fx:id="menuItemOpenProject"
                              text="Open Project..."
                              accelerator="Shortcut+O"
                              onAction="#handleOpenProject"/>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemSetEntrypoint"
                              text="Set Entrypoint"
                              accelerator="Shortcut+Shift+E"/>
                    <MenuItem fx:id="menuItemSetXmlInput"
                              text="Set XML Input"
                              accelerator="Shortcut+Shift+I"/>
                    <SeparatorMenuItem/>
                    <MenuItem fx:id="menuItemNewFile"
                              text="New File..."
                              accelerator="Shortcut+N"
                              onAction="#handleNewFile"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit"
                              accelerator="Shortcut+Q"
                              onAction="#handleExit"/>
                </Menu>
                <Menu text="Edit">
                    <MenuItem fx:id="undoMenuItem"
                              text="Undo"
                              accelerator="Shortcut+Z"
                              onAction="#handleEditUndo"/>
                    <MenuItem fx:id="redoMenuItem"
                              text="Redo"
                              accelerator="Shortcut+Shift+Z"
                              onAction="#handleEditRedo"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Cut"
                              accelerator="Shortcut+X"
                              onAction="#handleEditCut"/>
                    <MenuItem text="Copy"
                              accelerator="Shortcut+C"
                              onAction="#handleEditCopy"/>
                    <MenuItem text="Paste"
                              accelerator="Shortcut+V"
                              onAction="#handleEditPaste"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Select All"
                              accelerator="Shortcut+A"
                              onAction="#handleEditSelectAll"/>
                </Menu>
                <Menu text="View"/>
                <Menu text="Run">
                    <MenuItem fx:id="menuItemRender"
                              text="Render"
                              accelerator="F5"
                              onAction="#handleRender"/>
                </Menu>
                <Menu text="Search">
                    <MenuItem fx:id="findInFilesMenuItem" text="Find in Files"
                              accelerator="Shortcut+Shift+F" onAction="#handleFindInFiles"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About XSLEditor..." onAction="#handleAbout"/>
                </Menu>
            </MenuBar>
            <ToolBar>
                <Button fx:id="undoButton" text="↺" onAction="#handleToolbarUndo">
                    <tooltip><Tooltip text="Undo"/></tooltip>
                </Button>
                <Button fx:id="redoButton" text="↻" onAction="#handleToolbarRedo">
                    <tooltip><Tooltip text="Redo"/></tooltip>
                </Button>
                <Separator/>
                <Button fx:id="saveButton" text="💾" onAction="#handleToolbarSave">
                    <tooltip><Tooltip text="Save"/></tooltip>
                </Button>
                <Separator/>
                <Button fx:id="renderButton" text="Render" onAction="#handleRender">
                    <tooltip><Tooltip text="Render"/></tooltip>
                </Button>
            </ToolBar>
        </VBox>
    </top>

    <!-- CENTER: Outer horizontal SplitPane -->
    <!-- Left: file tree placeholder | Right: editor+preview SplitPane -->
    <center>
        <SplitPane fx:id="outerSplitPane" dividerPositions="0.20" orientation="HORIZONTAL">

            <!-- LEFT ZONE: file tree placeholder (Phase 3 fills this) -->
            <StackPane fx:id="fileTreePane" styleClass="placeholder-pane">
                <Label text="No project open. Use File &#8594; Open Project... to get started."
                       styleClass="placeholder-label"/>
                <Label fx:id="statusLabel"
                       styleClass="placeholder-label"
                       StackPane.alignment="BOTTOM_CENTER"
                       style="-fx-padding: 8;"/>
            </StackPane>

            <!-- RIGHT ZONE: inner horizontal SplitPane -->
            <!-- Left: editor | Right: PDF preview -->
            <SplitPane fx:id="innerSplitPane" dividerPositions="0.55" orientation="HORIZONTAL">

                <!-- EDITOR ZONE: placeholder (Phases 4-5 fill this) -->
                <StackPane fx:id="editorPane" styleClass="placeholder-pane">
                    <Label text="Editor" styleClass="placeholder-label"/>
                </StackPane>

                <!-- PREVIEW ZONE: WebView for PDF (Phase 7 wires this) -->
                <StackPane fx:id="previewPane" styleClass="placeholder-pane">
                    <WebView fx:id="previewWebView"
                             managed="false"
                             visible="false"/>
                    <Label fx:id="previewPlaceholderLabel"
                           text="No preview — trigger a render first"
                           styleClass="placeholder-label"/>
                    <Label fx:id="outdatedBannerLabel"
                           text="Preview outdated — last render failed"
                           styleClass="preview-outdated-banner"
                           managed="false"
                           visible="false"
                           maxWidth="Infinity"
                           StackPane.alignment="TOP_CENTER"/>
                </StackPane>

            </SplitPane>
        </SplitPane>
    </center>

    <!-- BOTTOM: Collapsible log panel (Phase 8 wires log entries) -->
    <bottom>
        <TitledPane fx:id="logPane" text="Log" expanded="false" styleClass="log-titled-pane">
            <VBox>
                <HBox spacing="4" styleClass="log-filter-bar">
                    <ToggleButton fx:id="filterAllButton"   text="All"     selected="true" styleClass="log-filter-btn"/>
                    <ToggleButton fx:id="filterErrorButton" text="Error"                   styleClass="log-filter-btn"/>
                    <ToggleButton fx:id="filterWarnButton"  text="Warning"                 styleClass="log-filter-btn"/>
                    <ToggleButton fx:id="filterInfoButton"  text="Info"                    styleClass="log-filter-btn"/>
                </HBox>
                <TableView fx:id="logTableView"
                           prefHeight="120" VBox.vgrow="ALWAYS">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colTime"    text="Time"    prefWidth="65"  minWidth="65"  maxWidth="65"  sortable="false"/>
                        <TableColumn fx:id="colLevel"   text="Level"   prefWidth="60"  minWidth="60"  maxWidth="60"  sortable="false"/>
                        <TableColumn fx:id="colType"    text="Type"    prefWidth="100" minWidth="80"  maxWidth="120" sortable="false"/>
                        <TableColumn fx:id="colMessage" text="Message" prefWidth="400" minWidth="120" maxWidth="1.7976931348623157E308" sortable="false"/>
                        <TableColumn fx:id="colAi"      text=""        prefWidth="40"  minWidth="40"  maxWidth="40"  sortable="false"/>
                    </columns>
                </TableView>
            </VBox>
        </TitledPane>
    </bottom>

</BorderPane>
